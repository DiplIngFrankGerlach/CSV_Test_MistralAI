// AppMain.ai
Import { 
   "Strings.ad", 
   "System.ad", 
   "Math.ad", 
   "ExpressionValuator_MISTRAL.ad"
}



// --- ExpressionEvaluator Implementierung ---
ExpressionEvaluator::ExpressionEvaluator()
{
    _pos = 0;
}

void ExpressionEvaluator::setExpression(&String_16 expr)
{
    _expression.assign(expr);
    _pos = 0;
}

void ExpressionEvaluator::skipWhitespace()
{
    while(_pos < _expression.length())
    {
        var char c = _expression.getAt(_pos);
        if(((c == ' ') || (c == '\t')) || ((c == '\n') || (c == '\r')))
        {
            _pos = _pos + 1;
        }
        else
        {
            return;
        }
    }
}

char ExpressionEvaluator::peekChar()
{
    this.skipWhitespace();
    if(_pos < _expression.length())
    {
        return _expression.getAt(_pos);
    }
    return '\0';
}

char ExpressionEvaluator::nextChar()
{
    this.skipWhitespace();
    if(_pos < _expression.length())
    {
        var char c = _expression.getAt(_pos);
        _pos = _pos + 1;
        return c;
    }
    return '\0';
}

int ExpressionEvaluator::isDigit(char c)
{
    if(((c >= '0') && (c <= '9')) || (c == '.'))
    {
        return 1;
    }
    return 0;
}

int ExpressionEvaluator::isAlpha(char c)
{
    if(((c >= 'a') && (c <= 'z')) || ((c >= 'A') && (c <= 'Z')))
    {
        return 1;
    }
    return 0;
}

double ExpressionEvaluator::parseNumber()
{
    var String_16 numStr;
    var char c = this.peekChar();

    if(c == '-')
    {
        numStr.append('-');
        this.nextChar();
        c = this.peekChar();
    }

    while((this.isDigit(c) == 1) || (c == '.'))
    {
        numStr.append(c);
        this.nextChar();
        c = this.peekChar();
    }

    inline_cpp[[ return atof(numStr._buffer); ]]
    return 0.0;
}

double ExpressionEvaluator::parseFunction()
{
    var String_16 funcName;
    var char c = this.nextChar();

    while(this.isAlpha(c) == 1)
    {
        funcName.append(c);
        c = this.nextChar();
    }

    if(c != '(')
    {
        return 0.0;
    }

    this.nextChar();
    var double arg = this.parseExpression();

    c = this.peekChar();
    if(c == ')')
    {
        this.nextChar();
    }
    else
    {
        return 0.0;
    }

    if(funcName.equals("sinus") == 1)
    {
        return _math.sinus(arg);
    }
    else
    {
        if(funcName.equals("cosinus") == 1)
        {
            return _math.cosinus(arg);
        }
        else
        {
            if(funcName.equals("sqrt") == 1)
            {
                return _math.wurzel(arg);
            }
            else
            {
                /*
                if(funcName.equals("log") == 1)
                {
                    return _math.log(arg);
                }
                else
                {
                    if(funcName.equals("abs") == 1)
                    {
                        return _math.abs(arg);
                    }
                    else
                    {
                        if(funcName.equals("pow") == 1)
                        {
                            c = this.peekChar();
                            if(c == ',')
                            {
                                this.nextChar();
                                var double exponent = this.parseExpression();
                                return _math.pow(arg, exponent);
                            }
                            return _math.pow(arg, 2.0);
                        }
                        else
                        {
                            return 0.0;
                        }
                    }
                }
                */
            }
        }
    } 
    return 0.0;
}

double ExpressionEvaluator::parseFactor()
{
    var char c = this.peekChar();
    var double result = 0.0;

    if(c == '(')
    {
        this.nextChar();
        result = this.parseExpression();
        c = this.peekChar();
        if(c == ')')
        {
            this.nextChar();
        }
    }
    else
    {
        if((c == '-') || (this.isDigit(c) == 1))
        {
            result = this.parseNumber();
        }
        else
        {
            if(this.isAlpha(c) == 1)
            {
                result = this.parseFunction();
            }
        }
    }

    return result;
}

double ExpressionEvaluator::parseTerm()
{
    var double result = this.parseFactor();
    var char c = this.peekChar();

    while((c == '*') || (c == '/'))
    {
        this.nextChar();
        var double nextFactor = this.parseFactor();

        if(c == '*')
        {
            result = result * nextFactor;
        }
        else
        {
            if(nextFactor == 0.0)
            {
                result = 0.0;
            }
            else
            {
                result = result / nextFactor;
            }
        }

        c = this.peekChar();
    }

    return result;
}

double ExpressionEvaluator::parseExpression()
{
    var double result = this.parseTerm();
    var char c = this.peekChar();

    while((c == '+') || (c == '-'))
    {
        this.nextChar();
        var double nextTerm = this.parseTerm();

        if(c == '+')
        {
            result = result + nextTerm;
        }
        else
        {
            result = result - nextTerm;
        }

        c = this.peekChar();
    }

    return result;
}

double ExpressionEvaluator::evaluate()
{
    _pos = 0;
    return this.parseExpression();
}

